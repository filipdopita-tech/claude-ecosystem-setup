{
  "_comment": "Claude Code settings template — zkopíruj do ~/.claude/settings.json a přizpůsob",
  "_setup_docs": "viz docs/SETUP_MAC.md pro instrukce",

  "env": {
    "CLAUDE_FLOW_HOOKS_ENABLED": "true",
    "CLAUDE_PLUGIN_ROOT": "$HOME/.claude",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "MAX_THINKING_TOKENS": "63999",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },

  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "NotebookEdit(*)",
      "TodoWrite(*)",
      "AskUserQuestion(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "EnterWorktree(*)",
      "ExitWorktree(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "CronList(*)",
      "RemoteTrigger(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "Skill(*)",
      "ToolSearch(*)"
    ],
    "deny": [],
    "_comment_defaultMode": "bypassPermissions = vše povoleno bez dotazu. Pokud chceš kontrolu, změn na 'default'",
    "defaultMode": "bypassPermissions"
  },

  "model": "sonnet",
  "enableAllProjectMcpServers": false,
  "effortLevel": "max",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,

  "_comment_statusLine": "Odkomentuj pokud máš statusline helper",
  "_statusLine_disabled": {
    "type": "command",
    "command": "node $HOME/.claude/helpers/statusline-combined.cjs"
  },

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/quality-gate-inject.sh\"",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-length-guard.sh\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/vps-safety-check.sh\"",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/security-guard.sh\"",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/standards-quality-gate.sh\"",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/model-routing-guard.js\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/send-guard.sh\"",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/context-bloat-pruner.sh\"",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/auto-formatter.sh\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/notify-done.sh\"",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/sync-memory-to-obsidian.sh\"",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/skill-feedback.sh\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/scripts/hooks/session-context-loader.sh\" 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-counter-reset.sh\" 2>/dev/null || true",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-check-update.js\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/stop-code-verify.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/stop-verify.sh\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-memory-flush.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pre-compact-context.sh\"",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-memory-flush.sh\"",
            "timeout": 5000
          }
        ]
      }
    ]
  },

  "_comment_mcpServers": "MCP servery — nastav sám podle docs/MCP_SERVERS.md",
  "mcpServers": {
    "_example_github": {
      "_comment": "GitHub MCP — vyžaduje GitHub PAT token v mcp-keys.env",
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT}"
      }
    },
    "_example_playwright": {
      "_comment": "Playwright browser automation — žádné credentials",
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@0.0.70",
        "--headless"
      ]
    },
    "_example_context7": {
      "_comment": "Context7 library docs — žádné credentials",
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
